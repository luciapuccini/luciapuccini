{
	"ci": {
		"collect": {
			"startServerCommand": "npm run preview -- --host 0.0.0.0 --port 4173",
			"startServerReadyPattern": "http://localhost:4173",
			"url": [
				"http://localhost:4173/",
				"http://localhost:4173/projects"
			],
			"numberOfRuns": 3
		},
		"upload": {
			"target": "temporary-public-storage"
		},
		"assert": {
			"assertions": {
				"categories:performance": [
					"error",
					{
						"minScore": 0.7
					}
				]
			}
		}
	}
}
